<!DOCTYPE html>
<html>
<head>

    <title>Forgot Password</title>

    <link rel="stylesheet" href="/css/style.css">

</head>
<body>

<div class="auth-wrapper">

    <div class="auth-card">

        <h2>Reset Password</h2>

        <form action="/forgot-password" method="POST">

            <input
                type="email"
                name="email"
                placeholder="Enter Email"
                required
            >

            <input
                type="password"
                name="password"
                placeholder="New Password"
                required
            >

            <button type="submit">
                Reset Password
            </button>

        </form>

    </div>

</div>

</body>
</html>