<!DOCTYPE html>

<html lang="en">

<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/css/style.css">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= recipe.title %></title>
</head>

<body>

<%- include("partials/navbar") %>

<div class="details-container">

    <div class="details-card">

        <img
            src="/uploads/<%= recipe.image %>"
            class="details-image"
            alt="<%= recipe.title %>"
        >

        <div class="details-content">

            <h1><%= recipe.title %></h1>

            <p class="chef">
                👨‍🍳 By <%= recipe.createdBy.username %>
            </p>

            <div class="section">
                <h2>Ingredients</h2>
                <p><%= recipe.ingredients %></p>
            </div>

            <div class="section">
                <h2>Instructions</h2>
                <p><%= recipe.instructions %></p>
            </div>

        </div>

    </div>

    <div class="comments-box">

        <h2>💬 Comments</h2>

        <% if(recipe.comments && recipe.comments.length > 0){ %>

            <% recipe.comments.forEach(comment => { %>

                <div class="comment-card">

                    <h4>
                        <%= comment.userId.username %>
                    </h4>

                    <p>
                        <%= comment.comment %>
                    </p>

                </div>

            <% }) %>

        <% } else { %>

            <p>No comments yet.</p>

        <% } %>

        <form
            action="/comment/add/<%= recipe._id %>"
            method="POST"
        >

            <textarea
                name="comment"
                placeholder="Write your comment..."
                required
            ></textarea>

            <button type="submit">
                Add Comment
            </button>

        </form>

    </div>

</div>

</body>

</html>
